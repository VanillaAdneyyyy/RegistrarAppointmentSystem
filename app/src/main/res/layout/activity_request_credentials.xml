<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/contentLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream">

    <!-- ===== BLUE GRADIENT HEADER ===== -->
    <LinearLayout
        android:id="@+id/topBarRequest"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingTop="40dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row: Back | Title | Bell -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/actionBarItemBackground"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="@null"
                android:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Request Credentials"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/buttonNotification"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/actionBarItemBackground"
                android:src="@drawable/ic_notification"
                android:contentDescription="@null" />

        </LinearLayout>

        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_marginTop="10dp"
            android:background="@color/secondary_dark_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Complete the form below to submit your credential request"
            android:textColor="#B2DFDB"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ===== SCROLLABLE FORM ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@color/background_cream"
        app:layout_constraintTop_toBottomOf="@id/topBarRequest"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationRequest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Form Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/secondary_dark_gold"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Application Details"
                            android:textColor="@color/primary_dark_green"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="16dp"
                            android:background="@color/divider_light" />

                        <!-- Credential Type Dropdown -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Requested Document"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/textInputCredentialType"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="@color/primary_dark_green"
                            app:hintTextColor="@color/primary_dark_green"
                            android:hint="Choose credential type">

                            <AutoCompleteTextView
                                android:id="@+id/autoCompleteCredentialType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:focusableInTouchMode="false"
                                android:inputType="none"
                                android:cursorVisible="false"
                                android:completionThreshold="0" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/textCredentialTypeError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/error_red"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:layout_marginTop="4dp" />

                        <!-- Multi-document checkbox list (populated dynamically) -->
                        <LinearLayout
                            android:id="@+id/checkboxContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="4dp" />

                        <!-- Price breakdown (shown when at least 1 doc selected) -->
                        <LinearLayout
                            android:id="@+id/priceBreakdownLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="end|center_vertical"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="4dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Total"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/textPriceTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱0.00"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@color/primary_dark_green" />

                        </LinearLayout>

                        <!-- Custom purpose for Others -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutCustomPurpose"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="@color/primary_dark_green"
                            app:hintTextColor="@color/primary_dark_green"
                            android:hint="Specify document type..."
                            android:visibility="gone">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editCustomPurpose"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapSentences"
                                android:maxLength="80" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Reason -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Purpose of Request"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/textInputReason"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="@color/primary_dark_green"
                            app:hintTextColor="@color/primary_dark_green"
                            android:hint="e.g. Transferring, Employment, Scholarship...">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editReason"
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:gravity="top|start"
                                android:inputType="textMultiLine|textCapSentences"
                                android:maxLength="150" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/textReasonError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/error_red"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:layout_marginTop="4dp" />

                        <!-- Former Student ID (guests only) -->
                        <LinearLayout
                            android:id="@+id/layoutGuestSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginTop="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Identity Verification"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Required for guest users"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginBottom="8dp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/textInputStudentId"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="@color/primary_dark_green"
                                app:hintTextColor="@color/primary_dark_green"
                                android:hint="Former Student ID No. (e.g. 2019-00123)">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editStudentIdNumber"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLength="30" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/textStudentIdError"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/error_red"
                                android:textSize="12sp"
                                android:visibility="gone"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Enter your old PUP/PHINMA student ID so the registrar can locate your records."
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"
                                android:lineSpacingMultiplier="1.4"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressBar"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            android:layout_marginTop="12dp"
                            android:layout_gravity="center_horizontal" />

                        <TextView
                            android:id="@+id/textSubmitStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:visibility="gone"
                            android:layout_marginTop="8dp" />

                        <Button
                            android:id="@+id/buttonSubmit"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="20dp"
                            android:backgroundTint="@color/primary_dark_green"
                            android:text="Submit Application"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Reminders Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/accent_gold_light"
                    app:strokeWidth="0dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quick Reminders"
                            android:textColor="@color/secondary_dark_gold_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Processing takes 3-5 working days."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="You will be notified once your document is ready for pickup."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Bring a valid ID when claiming your document."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border_gold"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Office Hours: Mon - Fri | 8:00 AM - 5:00 PM"
                            android:textColor="@color/secondary_dark_gold_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Closed on weekends and holidays"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationRequest"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/primary_dark_green"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/menu_bottom_navigation" />

</androidx.constraintlayout.widget.ConstraintLayout>