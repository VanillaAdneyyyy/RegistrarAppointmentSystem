<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with School Palette: Dark Green & Dark Gold -->
    <style name="Base.Theme.RegistarAppointmentSystem" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary: Dark Green -->
        <item name="colorPrimary">@color/primary_dark_green</item>
        <item name="colorPrimaryVariant">@color/primary_dark_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary: Dark Gold -->
        <item name="colorSecondary">@color/secondary_dark_gold</item>
        <item name="colorSecondaryVariant">@color/secondary_dark_gold_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/background_cream</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark_green_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Button styles -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
    </style>

    <style name="Theme.RegistarAppointmentSystem" parent="Base.Theme.RegistarAppointmentSystem" />

    <style name="Theme.RegistrarAppointmentSystem" parent="Base.Theme.RegistarAppointmentSystem" />
    
    <!-- Custom Button Style -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_dark_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    
    <!-- Gold Accent Button -->
    <style name="Widget.App.Button.Gold" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/secondary_dark_gold</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <!-- Outlined Button -->
    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_dark_green</item>
        <item name="android:textColor">@color/primary_dark_green</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
